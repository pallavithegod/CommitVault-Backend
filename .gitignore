# Dependencies
node_modules/

# Environment Variables (Security)
.env
.env.*

# Logs (If your server crashes, NPM creates huge log files. We don't want those on GitHub)
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS Generated Files (Keeps Mac/Windows junk files out of the repo)
.DS_Store
Thumbs.db

# Editor directories and files (Keeps your personal VS Code settings private)
.vscode/
.idea/